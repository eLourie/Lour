# =============================================================================
#  AI Agent — reference config (M4 24GB, Split profile)
#  Copy to .env and fill in secrets.
#  All backing services are attached resources — swap address, not code.
# =============================================================================

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
APP_ENV=development                # development | staging | production
APP_LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
APP_LOG_FORMAT=json                # json (always-on baseline) | console (pretty dev output)
APP_API_KEY=changeme-user          # API key for regular access
APP_ADMIN_API_KEY=changeme-admin   # API key for admin routes
AUTH_MODE=apikey                   # apikey (core) | jwt (showcase)

# ---------------------------------------------------------------------------
# Gateway hardening (Phase 7) — rate limiting, CORS, security headers, JWT
# ---------------------------------------------------------------------------
# Rate limiting: Redis fixed-window, per-route budgets (requests per window).
GATEWAY_RATE_LIMIT_ENABLED=true
GATEWAY_RATE_LIMIT_WINDOW_S=60
GATEWAY_RATE_LIMIT_DEFAULT=120     # reads and everything else
GATEWAY_RATE_LIMIT_CHAT=30         # /v1/chat — expensive agent turns
GATEWAY_RATE_LIMIT_INGEST=10       # /v1/rag/ingest — heavy, bursty

# CORS: comma-separated origins. Empty = no cross-origin access (safe default).
GATEWAY_CORS_ALLOW_ORIGINS=
GATEWAY_CORS_ALLOW_CREDENTIALS=false

# Security headers: enable HSTS only when served over TLS.
GATEWAY_HSTS_ENABLED=false
GATEWAY_HSTS_MAX_AGE=31536000

# JWT (showcase, AUTH_MODE=jwt): symmetric HS256 by default.
JWT_SECRET=changeme-jwt-secret
GATEWAY_JWT_ALGORITHM=HS256
GATEWAY_JWT_EXPIRY_S=3600

# ---------------------------------------------------------------------------
# Deployment topology (backing-services)
# ---------------------------------------------------------------------------
# solo       — everything on one machine, incl. Langfuse self-host
# split      — Ollama+app+PG/Redis/Qdrant local, Langfuse Cloud + cloud LLM optional
# offloaded  — only Ollama+app local, all backing services in cloud
DEPLOY_PROFILE=split

# ---------------------------------------------------------------------------
# LLM (attached resource)
# ---------------------------------------------------------------------------
LLM_PROVIDER=ollama               # ollama | anthropic | openai | vllm

# Main model — one model for everything including routing (no separate fast model)
LLM_MAIN_MODEL=qwen3:14b
# LLM_FAST_MODEL=                 # empty = main model routes itself (reference config)

# Ollama runs natively on the host (Metal; NOT in Docker on mac)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_TIMEOUT_S=120

# Reliability tier — optional, for long multi-step tool chains
# where the local 14B loses coherence. Uses the same LLMProvider Protocol.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Embeddings / Sparse / Rerank
# ---------------------------------------------------------------------------
LLM_EMBED_MODEL=bge-m3                                  # dense via Ollama
SPARSE_MODEL=Qdrant/bm42-all-minilm-l6-v2-attentions   # sparse via FastEmbed (not Ollama)

# Reranker runs OUTSIDE Ollama (no /api/rerank endpoint) — native MPS service
RERANKER_MODE=local               # local | cloud | none
RERANKER_MODEL=bge-reranker-v2-m3
RERANKER_BASE_URL=http://host.docker.internal:8081
RERANKER_LAZY_LOAD=true           # load on first request, unload after idle

# If RERANKER_MODE=cloud:
# COHERE_API_KEY=

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent
POSTGRES_USER=agent
POSTGRES_PASSWORD=changeme

# LangGraph checkpoint DB (separate schema, same host)
POSTGRES_CHECKPOINT_DB=agent_checkpoint

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB_CACHE=0       # embedding cache, tool result cache
REDIS_DB_MEMORY=1      # short-term memory (sliding window)
REDIS_DB_RATELIMIT=2   # rate limiting counters

# ---------------------------------------------------------------------------
# Qdrant
# ---------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_DOCS=documents
QDRANT_COLLECTION_MEMORY=memories

# ---------------------------------------------------------------------------
# Observability (attached resource)
# ---------------------------------------------------------------------------
# langfuse_cloud   — Langfuse Cloud (free tier); recommended for Split profile
# langfuse_selfhost — heavy (ClickHouse+MinIO+Redis+PG); only on powerful hardware
# none             — structlog JSON baseline only (always active, zero extra memory)
TELEMETRY_BACKEND=langfuse_cloud

LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# structlog JSON baseline is ALWAYS active — no config needed

# ---------------------------------------------------------------------------
# Web search (env-switchable, both behind same tool interface)
# ---------------------------------------------------------------------------
WEB_SEARCH_PROVIDER=tavily        # tavily | searxng
TAVILY_API_KEY=

# SearXNG (self-host, privacy, free) — only if WEB_SEARCH_PROVIDER=searxng
# SEARXNG_BASE_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# Agent budget defaults
# ---------------------------------------------------------------------------
AGENT_MAX_ITERATIONS=10
AGENT_MAX_TOOL_CALLS=20
AGENT_BUDGET_TOKENS=100000

# ---------------------------------------------------------------------------
# Memory system (Phase 4) — short-term / long-term / episodic
# ---------------------------------------------------------------------------
MEMORY_SHORT_TERM_WINDOW=20              # turns kept verbatim before tail summarisation
MEMORY_SHORT_TERM_TTL_S=86400            # idle working-window expiry (1 day)
MEMORY_LONG_TERM_TOP_K=5                 # memories returned by recall
MEMORY_CANDIDATE_MULTIPLIER=6            # over-fetch factor before re-ranking
# Long-term ranking: score = alpha*cosine + beta*recency + gamma*importance
MEMORY_SCORE_ALPHA=0.6
MEMORY_SCORE_BETA=0.2
MEMORY_SCORE_GAMMA=0.2
MEMORY_RECENCY_HALF_LIFE_H=72.0          # recency halves every N hours
MEMORY_CONSOLIDATION_ENABLED=true        # APScheduler background distillation (ADR-012)
MEMORY_CONSOLIDATION_INTERVAL_S=3600
MEMORY_DEDUP_THRESHOLD=0.9               # cosine >= this ⇒ duplicate fact, skipped
MEMORY_MIN_IMPORTANCE=0.3                # facts below this importance are not stored

# ---------------------------------------------------------------------------
# Sandbox (code execution)
# ---------------------------------------------------------------------------
SANDBOX_MEMORY_MB=512
SANDBOX_CPU_QUOTA=1.0
SANDBOX_TIMEOUT_S=30
SANDBOX_PIDS_LIMIT=128
SANDBOX_PYTHON_IMAGE=python:3.12-slim   # docker pull before first code_exec
SANDBOX_NODE_IMAGE=node:20-slim

# ---------------------------------------------------------------------------
# Tools layer (Phase 3)
# ---------------------------------------------------------------------------
TOOLS_WORKSPACE_DIR=./workspace         # filesystem tool is confined here (traversal-guarded)
TOOLS_HTTP_ALLOWLIST=                    # comma-separated hosts http_request may reach
TOOLS_CACHE_TTL_S=300                    # result cache TTL for idempotent tools

# ---------------------------------------------------------------------------
# MCP — external servers this instance connects to as a client (ADR-006)
# ---------------------------------------------------------------------------
# JSON map of stdio servers, e.g.:
#   MCP_SERVERS_JSON={"filesystem":{"command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/tmp"]}}
# Empty = MCP client dormant.
MCP_SERVERS_JSON=
